# Agent server
AGENT_HOST=0.0.0.0
AGENT_PORT=8081
PYTHON_LOG_LEVEL=INFO

# In-memory mode (set to false to use PostgreSQL)
USE_INMEMORY_SAVER=true

# Google Gemini (required — FREE tier available)
# Get your free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# MCP Server connection
MCP_SERVER_NAME=str-mcp-server
MCP_SERVER_URL=http://localhost:5001/mcp/
MCP_TRANSPORT_PROTOCOL=streamable_http
MCP_CONNECTION_TIMEOUT=30

# Langfuse tracing (optional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=
